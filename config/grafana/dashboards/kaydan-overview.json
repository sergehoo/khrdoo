{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Kaydan ERP — Vue d'ensemble",
  "uid": "kaydan-overview",
  "tags": ["kaydan", "erp"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU hôte (%)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Mémoire hôte utilisée (%)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM" }
      ]
    },
    {
      "type": "gauge",
      "title": "Espace disque utilisé (/)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/host\"} / node_filesystem_size_bytes{mountpoint=\"/host\"})) * 100", "legendFormat": "disque" }
      ]
    },
    {
      "type": "stat",
      "title": "Connexions PostgreSQL",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 150 }, { "color": "red", "value": 190 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(pg_stat_activity_count)", "legendFormat": "connexions" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Mémoire par conteneur Kaydan",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "container_memory_usage_bytes{name=~\"kaydan-.*\"}", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "logs",
      "title": "Logs Odoo (erreurs récentes)",
      "datasource": "Loki",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "expr": "{container=\"kaydan-odoo\"} |~ \"(?i)(error|critical|traceback)\"" }
      ]
    }
  ]
}
