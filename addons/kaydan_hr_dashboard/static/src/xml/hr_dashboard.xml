<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Liste de barres horizontales réutilisable (attend "barItems" en scope) -->
    <t t-name="kaydan_hr_dashboard.BarList">
        <t t-if="barItems.length === 0">
            <div class="text-muted">Aucune donnée</div>
        </t>
        <t t-foreach="barItems" t-as="b" t-key="b_index">
            <div class="o_kd_bar">
                <span class="o_kd_bar_lbl" t-esc="b.label"/>
                <div class="o_kd_bar_track">
                    <div class="o_kd_bar_fill" t-att-style="`width: ${b.pct}%`"/>
                </div>
                <span class="o_kd_bar_val" t-esc="b.value"/>
            </div>
        </t>
    </t>

    <!-- Tableau de bord principal -->
    <t t-name="kaydan_hr_dashboard.Dashboard">
        <div class="o_kaydan_hr p-4">
            <div class="o_kaydan_hr_header d-flex align-items-center flex-wrap gap-2 mb-4">
                <h2 class="mb-0">Tableau de bord RH</h2>
                <span class="o_kd_badge">Kaydan</span>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <select class="form-select form-select-sm o_kd_company"
                            t-on-change="(ev) => this.onCompanyChange(ev)">
                        <option value="">Toutes les sociétés</option>
                        <t t-foreach="state.data.companies" t-as="c" t-key="c.id">
                            <option t-att-value="c.id" t-att-selected="c.id === state.companyId ? 'selected' : false" t-esc="c.name"/>
                        </t>
                    </select>
                    <button class="btn btn-sm btn-secondary" t-on-click="() => this.load()">↻</button>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="text-muted">Chargement des indicateurs…</div>
            </t>
            <t t-else="">
                <!-- KPIs -->
                <div class="o_kd_cards">
                    <t t-foreach="cards" t-as="c" t-key="c.label">
                        <div class="o_kd_card">
                            <div class="o_kd_val" t-esc="c.value"/>
                            <div class="o_kd_lbl" t-esc="c.label"/>
                        </div>
                    </t>
                </div>

                <!-- Évolution des effectifs (12 mois) -->
                <div class="o_kd_panel mt-4">
                    <h5>Évolution des effectifs (12 mois)</h5>
                    <div class="o_kd_vbars">
                        <t t-foreach="state.data.evolution" t-as="m" t-key="m.label">
                            <div class="o_kd_vbar" t-att-title="m.value">
                                <span class="o_kd_vbar_num" t-esc="m.value"/>
                                <div class="o_kd_vbar_wrap">
                                    <div class="o_kd_vbar_fill" t-att-style="`height: ${m.pct}%`"/>
                                </div>
                                <span class="o_kd_vbar_lbl" t-esc="m.label"/>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Département / Genre -->
                <div class="row mt-3">
                    <div class="col-lg-7 mb-3">
                        <div class="o_kd_panel">
                            <h5>Effectif par département</h5>
                            <t t-call="kaydan_hr_dashboard.BarList">
                                <t t-set="barItems" t-value="state.data.by_department"/>
                            </t>
                        </div>
                    </div>
                    <div class="col-lg-5 mb-3">
                        <div class="o_kd_panel">
                            <h5>Répartition par genre</h5>
                            <t t-call="kaydan_hr_dashboard.BarList">
                                <t t-set="barItems" t-value="state.data.by_gender"/>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Type de contrat / Statut -->
                <div class="row">
                    <div class="col-lg-6 mb-3">
                        <div class="o_kd_panel">
                            <h5>Effectif par type de contrat</h5>
                            <t t-if="state.data.by_contract_type.length === 0">
                                <div class="text-muted">Module Contrats (hr_contract) requis</div>
                            </t>
                            <t t-else="">
                                <t t-call="kaydan_hr_dashboard.BarList">
                                    <t t-set="barItems" t-value="state.data.by_contract_type"/>
                                </t>
                            </t>
                        </div>
                    </div>
                    <div class="col-lg-6 mb-3">
                        <div class="o_kd_panel">
                            <h5>Effectif par statut</h5>
                            <t t-call="kaydan_hr_dashboard.BarList">
                                <t t-set="barItems" t-value="state.data.by_employee_type"/>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Top congés / Top départs -->
                <div class="row">
                    <div class="col-lg-6 mb-3">
                        <div class="o_kd_panel">
                            <h5>Top congés par employé (année)</h5>
                            <t t-if="state.data.top_leaves.length === 0">
                                <div class="text-muted">Aucun congé validé (ou module Congés absent)</div>
                            </t>
                            <t t-else="">
                                <t t-call="kaydan_hr_dashboard.BarList">
                                    <t t-set="barItems" t-value="state.data.top_leaves"/>
                                </t>
                            </t>
                        </div>
                    </div>
                    <div class="col-lg-6 mb-3">
                        <div class="o_kd_panel">
                            <h5>Top départs par motif (12 mois)</h5>
                            <t t-if="state.data.top_departures.length === 0">
                                <div class="text-muted">Aucun départ enregistré</div>
                            </t>
                            <t t-else="">
                                <t t-call="kaydan_hr_dashboard.BarList">
                                    <t t-set="barItems" t-value="state.data.top_departures"/>
                                </t>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Recrutement récent -->
                <div class="o_kd_panel">
                    <h5>Recrutement récent</h5>
                    <div class="o_kd_cards o_kd_cards_sm mb-3">
                        <t t-foreach="state.data.recruitment" t-as="r" t-key="r.label">
                            <div class="o_kd_card">
                                <div class="o_kd_val" t-esc="r.value"/>
                                <div class="o_kd_lbl" t-esc="r.label"/>
                            </div>
                        </t>
                    </div>
                    <table class="table table-sm o_kd_table">
                        <thead>
                            <tr><th>Employé</th><th>Département</th><th>Arrivée</th></tr>
                        </thead>
                        <tbody>
                            <t t-if="state.data.recent_arrivals.length === 0">
                                <tr><td colspan="3" class="text-muted">Aucune arrivée récente</td></tr>
                            </t>
                            <t t-foreach="state.data.recent_arrivals" t-as="a" t-key="a_index">
                                <tr>
                                    <td t-esc="a.name"/>
                                    <td t-esc="a.department"/>
                                    <td t-esc="a.date"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </div>
    </t>

</templates>
