# ============================================================================
#  KAYDAN ERP — Fichier d'environnement (TEMPLATE)
# ----------------------------------------------------------------------------
#  1. Copier ce fichier :            cp .env.example .env
#  2. Générer les secrets :          make secrets   (ou openssl rand -base64 36)
#  3. Renseigner DOMAIN + ACME_EMAIL
#  4. JAMAIS committer le fichier .env (voir .gitignore)
#  Permissions recommandées :        chmod 600 .env
# ============================================================================

# ---------------------------------------------------------------------------
# GÉNÉRAL
# ---------------------------------------------------------------------------
# Domaine racine. Les sous-domaines suivants doivent pointer (A/AAAA) vers le VPS :
#   erp.${DOMAIN}      -> Odoo
#   pgadmin.${DOMAIN}  -> pgAdmin
#   grafana.${DOMAIN}  -> Grafana
#   s3.${DOMAIN}       -> MinIO API
#   minio.${DOMAIN}    -> MinIO Console
# (Keycloak/SSO est EXTERNE : son sous-domaine pointe vers l'instance existante,
#  pas vers ce VPS — voir la section KEYCLOAK plus bas.)
DOMAIN=kaydan.example.com

# Hôte HTTPS d'Odoo. Par défaut erp.${DOMAIN}. Mettez le nom complet si différent.
# Ex. : ODOO_HOST=rh.kaydanshield.com
ODOO_HOST=erp.kaydan.example.com

# Email pour Let's Encrypt (notifications d'expiration de certificat)
ACME_EMAIL=admin@kaydan.example.com

# Fuseau horaire (ex: Africa/Abidjan, Europe/Paris, UTC)
TZ=UTC

# Profil de ressources ACTIF : small | medium | enterprise
# Appliqué par scripts/tune.sh -> génère config/odoo/odoo.conf
ODOO_PROFILE=medium

# ---------------------------------------------------------------------------
# POSTGRESQL 16
# ---------------------------------------------------------------------------
POSTGRES_VERSION=16
POSTGRES_DB=postgres
POSTGRES_USER=odoo
# >>> openssl rand -base64 36
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password

# Utilisateur de monitoring (postgres-exporter), créé par init SQL
PG_EXPORTER_USER=odoo_exporter
PG_EXPORTER_PASSWORD=CHANGE_ME_exporter_password

# ---------------------------------------------------------------------------
# ODOO 18 (Community + OCA)
# ---------------------------------------------------------------------------
ODOO_VERSION=18
# Mot de passe maître (création/suppression/restauration de bases) — TRÈS sensible
# >>> openssl rand -base64 36
ODOO_ADMIN_PASSWD=CHANGE_ME_odoo_master_password
# Base par défaut proposée à la connexion (dbfilter)
ODOO_DB_NAME=kaydan

# ---------------------------------------------------------------------------
# REDIS (cache / sessions via OCA session_redis — optionnel)
# ---------------------------------------------------------------------------
# >>> openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_redis_password

# ---------------------------------------------------------------------------
# pgAdmin
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@kaydan.example.com
# >>> openssl rand -base64 24
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_pgadmin_password

# ---------------------------------------------------------------------------
# MinIO (stockage objet S3 — cible des sauvegardes hors-conteneur)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=kaydan-minio-admin
# >>> openssl rand -base64 36
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=kaydan-backups

# ---------------------------------------------------------------------------
# SAUVEGARDES (service backup)
# ---------------------------------------------------------------------------
# Chiffrement AES-256 des archives (PII at-rest). Vide = pas de chiffrement (NON recommandé)
# >>> openssl rand -base64 48
BACKUP_PASSPHRASE=CHANGE_ME_backup_encryption_passphrase
# Rétention (en nombre d'archives conservées par type)
BACKUP_RETENTION_DAILY=30
BACKUP_RETENTION_WEEKLY=8
BACKUP_RETENTION_MONTHLY=12
# Planification cron du backup quotidien (HH:MM via crond) — 02:00
BACKUP_CRON=0 2 * * *
# Pousser une copie chiffrée vers MinIO/S3 (true/false)
BACKUP_S3_ENABLED=true
BACKUP_S3_ENDPOINT=http://minio:9000
BACKUP_S3_BUCKET=kaydan-backups

# ---------------------------------------------------------------------------
# GRAFANA
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
# >>> openssl rand -base64 24
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ---------------------------------------------------------------------------
# KEYCLOAK (SSO / K-Access) — service EXTERNE déjà en production
# ---------------------------------------------------------------------------
# On NE déploie PAS Keycloak ici : Odoo se connecte à l'instance existante (OIDC).
# Ces valeurs servent à configurer le fournisseur OAuth/OIDC côté Odoo
# (auth_oidc) — voir docs/19-sso-keycloak.md.
# URL de base de l'instance Keycloak existante (sans / final)
KEYCLOAK_URL=https://sso.kaydan.example.com
# Realm utilisé pour l'ERP
KEYCLOAK_REALM=kaydan
# Client OIDC déclaré dans le realm pour Odoo
KEYCLOAK_ODOO_CLIENT_ID=odoo
# Secret du client (fourni par l'administrateur du Keycloak existant)
KEYCLOAK_ODOO_CLIENT_SECRET=CHANGE_ME_odoo_oidc_client_secret

# ---------------------------------------------------------------------------
# WATCHTOWER (mises à jour contrôlées)
# ---------------------------------------------------------------------------
# Par défaut MONITOR ONLY = true : Watchtower notifie mais NE met PAS à jour
# automatiquement (sécurité). Passez à false pour activer l'auto-update planifié.
WATCHTOWER_MONITOR_ONLY=true
# Cron 6 champs (sec min hour dom mon dow) — 04:00 chaque jour
WATCHTOWER_SCHEDULE=0 0 4 * * *
